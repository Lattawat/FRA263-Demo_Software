# Copy this file to .env and edit as needed.
# Used by docker-compose.yml (hardware mode).

# USB serial device path for the Teensy 4.1
# Linux / WSL2:  /dev/ttyACM0  (most common — verify with: ls /dev/ttyACM*)
SERIAL_PORT=/dev/ttyACM0

# ROS 2 DDS domain ID (0–232)
# Change only if multiple ROS 2 systems run on the same network simultaneously.
ROS_DOMAIN_ID=156