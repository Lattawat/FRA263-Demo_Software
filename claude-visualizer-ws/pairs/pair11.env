# Pair 11 environment — source on EACH machine this pair spans.
#   Verifier machine: ROS_DOMAIN_ID (ROS graph isolation) + CV_PAIR_ID (LSL suffix) + derived ports.
#   Robot machine:    CV_PAIR_ID (LSL suffix) only.
# Example file. Regenerate any pair with: scripts/make_pair_env.sh <N>
export ROS_DOMAIN_ID=11
export CV_PAIR_ID=11
